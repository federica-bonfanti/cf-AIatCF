{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "cf-ai-infographic",
  "title": "CF AI Infographic — Monthly Data",
  "type": "object",
  "required": ["meta", "featured", "tooling", "client_pipeline", "weekly_ai_call", "evangelist_shoutouts"],
  "additionalProperties": false,

  "properties": {

    "meta": {
      "type": "object",
      "required": ["month", "theme"],
      "additionalProperties": false,
      "properties": {
        "month": {
          "type": "string",
          "description": "Month name only, e.g. 'April'"
        },
        "theme": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
              "enum": ["default", "easter", "summer", "halloween", "christmas"]
            },
            "footer_note": {
              "type": ["string", "null"],
              "description": "Optional fun line shown in the footer, e.g. 'Happy Easter 🐣'"
            }
          }
        }
      }
    },

    "featured": {
      "type": "object",
      "required": ["featured_item_title", "subject_subtitle", "summary", "link"],
      "additionalProperties": false,
      "properties": {
        "featured_item_title": {
          "type": "string",
          "description": "Speaker name or event title shown large on the card"
        },
        "subject_subtitle": {
          "type": "string",
          "description": "Role or short descriptor under the title"
        },
        "summary": {
          "type": "string",
          "description": "2–3 sentences, plain text"
        },
        "link": {
          "type": "string",
          "description": "URL for the CTA button"
        }
      }
    },

    "tooling": {
      "type": "object",
      "required": ["tools"],
      "additionalProperties": false,
      "properties": {
        "tools": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "description": "Exactly 5 tools",
          "items": {
            "type": "object",
            "required": ["name", "status"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["In Trial", "Adopted", "Dropped", "Evaluating"]
              }
            }
          }
        }
      }
    },

    "client_pipeline": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "description": "Exactly 4 client cards",
      "items": {
        "type": "object",
        "required": ["client_name", "project_title", "ask", "answer", "value"],
        "additionalProperties": false,
        "properties": {
          "client_name": {
            "type": "string",
            "description": "Client name shown small at top of card"
          },
          "project_title": {
            "type": "string",
            "description": "Project name shown large"
          },
          "ask": {
            "type": "string",
            "description": "What the client asked for, 1–2 sentences"
          },
          "answer": {
            "type": "string",
            "description": "What CF proposed or delivered, 1–2 sentences"
          },
          "value": {
            "type": "string",
            "description": "Monetary value e.g. '£1m'"
          }
        }
      }
    },

    "weekly_ai_call": {
      "type": "object",
      "required": ["metrics"],
      "additionalProperties": false,
      "properties": {
        "metrics": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "description": "Exactly 4 metrics",
          "items": {
            "type": "object",
            "required": ["value", "label"],
            "additionalProperties": false,
            "properties": {
              "value": {
                "type": "string",
                "description": "Bold stat e.g. '40%' or '1/wk'"
              },
              "label": {
                "type": "string",
                "description": "Short descriptor under the number"
              }
            }
          }
        }
      }
    },

    "evangelist_shoutouts": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "description": "Exactly 3 shoutout cards",
      "items": {
        "type": "object",
        "required": ["client_and_project", "lead", "key_metric_large", "key_metric_small", "key_insight"],
        "additionalProperties": false,
        "properties": {
          "client_and_project": {
            "type": "string",
            "description": "Project name shown at top of card"
          },
          "lead": {
            "type": "string",
            "description": "CF lead's name"
          },
          "key_metric_large": {
            "type": "string",
            "description": "Big bold number or word e.g. '160+'"
          },
          "key_metric_small": {
            "type": "string",
            "description": "Smaller supporting stat or label"
          },
          "key_insight": {
            "type": "string",
            "description": "1–2 sentence takeaway shown at the bottom of the card"
          }
        }
      }
    }

  }
}
